{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "mvl",
      "camelcase": "Mvl",
      "scope": "source.mvl",
      "path": ".",
      "file-types": [
        "mvl"
      ],
      "highlights": "queries/highlights.scm",
      "injection-regex": "^mvl$"
    }
  ],
  "metadata": {
    "version": "0.0.1",
    "license": "MIT",
    "description": "Tree-sitter grammar for MVL (Minimum Verification Language)",
    "authors": [
      {
        "name": "MVL Team",
        "email": "mvl-lang@schubergphilis.com"
      }
    ],
    "links": {
      "repository": "https://github.com/mvl-lang/mvl-spec"
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}